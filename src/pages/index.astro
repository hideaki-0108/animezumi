---
import { BASE_PATH } from '../assets/js/lib/config';
import Layout from '../layouts/Layout.astro';
import { gsap } from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';
import ButtonPrimary from '../components/ButtonPrimary.astro';
import ButtonSecondary from '../components/ButtonSecondary.astro';
import TitlePrimary from '../components/TitlePrimary.astro';
import ButtonTertiary from '../components/ButtonTertiary.astro';
import type { AnimationTag } from '@/assets/js/utils/animationTagMaster';

gsap.registerPlugin(ScrollTrigger);

// meta
const title = 'ANIMEZUMI - Webサイトのアニメーション集';
const description =
  '様々なアニメーションテクニックを探求し、インスピレーションあふれる表現を集めたポートフォリオANIMEZUMI。';

const animationModules = import.meta.glob('../animations/*.astro', {
  eager: true,
});
const featuredAnimations = Object.values(animationModules)
  .map((mod: any) => ({
    meta: mod.meta,
    Component: mod.default,
  }))
  .sort((a, b) => (a.meta.order ?? 999) - (b.meta.order ?? 999))
  .slice(0, 4);

// 使用技術（Technologies)セクションに表示するアイテム
const useTech = [
  {
    title: 'Astro',
    description: 'FRAMEWORK',
  },
  {
    title: 'CSS Animation(Sass)',
    description: 'CORE',
  },
  {
    title: 'GSAP',
    description: 'CORE',
  },
  {
    title: 'SVG Animation',
    description: 'CORE',
  },
  {
    title: 'WebGL',
    description: 'ADVANCED',
  },
  {
    title: 'Three.js',
    description: 'ADVANCED',
  },
];
---

<Layout title={title} description={description}>
  <div class='container'>
    <!-- FirstView Section -->
    <section class='top__fv topFv'>
      <h1 class='topFv__title'>
        <span class='topFv__title--primary'>ANIME</span>
        <span class='topFv__title--secondary'>ZUMI</span>
      </h1>
      <p class='topFv__keyword'>ANIMATION IDEAS COLLECTION</p>
      <p class='topFv__description'>
        様々なアニメーションテクニックを探求し、
        <span class='topFv__description--break'
          >インスピレーションあふれる表現を集めたポートフォリオ ANIMEZUMI。</span
        ><br />
        <span class='topFv__description--break'
          >Webデザイナーやフロントエンドエンジニアの「動きのアイデア帳」を目指しています。</span
        >
      </p>
      <div class='topFv__cta'>
        <ButtonPrimary label='作品を見る' href='./animations/' />
        <ButtonSecondary label='詳しく知る' href='./#about' />
      </div>
      <div class='topFv__scroll'>
        <p class='topFv__scroll--text'>SCROLL</p>
        <span class='topFv__scroll--line'></span>
      </div>
    </section>
    <!-- /FirstView Section -->

    <!-- Animations Section -->
    <section id='animations' class='top__animation topAnimation'>
      <TitlePrimary label='ANIMATIONS' num='01' />
      <ul class='topAnimation__list animationCard'>
        {
          featuredAnimations.map((item) => (
            <li class='topAnimation__item animationCard__item'>
              <a
                class='animationCard__link'
                href={`${BASE_PATH}animations/${item.meta.slug}`}
              >
                <div class='animationCard__preview'>
                  <div class='animationCard__previewInner'>
                    <item.Component preview={true} />
                  </div>
                </div>
                <div class='animationCard__description'>
                  <h3 class='animationCard__title'>{item.meta.title}</h3>
                  <p class='animationCard__text'>{item.meta.description}</p>
                  <ul class='animationCard__tag'>
                    {item.meta.tags.primary.map((tag: AnimationTag) => {
                      return <li class='animationCard__tagItem'>{tag}</li>;
                    })}

                    {() => {
                      if (item.meta.tags.free) {
                        return item.meta.tags.free.map((tag: string) => {
                          return <li class='animationCard__tagItem'>{tag}</li>;
                        });
                      }
                    }}
                  </ul>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
      <div class='topAnimation__cta'>
        <ButtonTertiary href='./animations/' />
      </div>
    </section>
    <!-- /Animations Section -->

    <!-- About Section -->
    <section id='about' class='topAbout top__about'>
      <TitlePrimary label='ABOUT' num='02' />

      <section>
        <h3 class='topAbout__subTitle'>
          「ズミ」は宮古島の方言で「最高」を意味します。
        </h3>
        <div class='topAbout__description'>
          <p>
            Animezumiは、クリエイティブなアニメーションを追求し、表現の可能性を広げるプロジェクトを目指しています。
          </p>
          <p>
            モーションデザイン、インタラクティブアニメーション、エフェクトなど、さまざまな技術を組み合わせた作品を集めています。
          </p>
        </div>
        <div>
          <p class='topAbout__concept'>
            アニメーション + ズミ（最高）<span class='topAbout__concept--space'
              >=</span
            ><span>ANIMEZUMI</span>
          </p>
        </div>
      </section>
      <section>
        <h3 class='topAbout__title'>Technologies</h3>
        <ul class='topAbout__tech'>
          {
            useTech.map((item) => (
              <li class='topAbout__techItem'>
                <p class='topAbout__techTitle'>{item.title}</p>
                <p class='topAbout__techPara'>{item.description}</p>
              </li>
            ))
          }
        </ul>
      </section>
    </section>
    <!-- /About Section -->
  </div>
</Layout>

<style lang='scss'>
  @use '../assets/css/pages/_top.scss';
  @use '../assets/css/components/_card.scss';
</style>
