---
const { label, num } = Astro.props;
---

<div class="titlePrimary">
  {
    () => {
      if (num !== null) {
        return <span class="titlePrimary__num">{num}</span>;
      }
    }
  }
  <h2 class="titlePrimary__label">{label}</h2>
</div>

<style lang="scss">
  @use '../assets/css/abstracts/_variables.scss' as *;
  @use '../assets/css/abstracts/mixins' as *;
  @use '../assets/css/base/typography' as *;

  .titlePrimary {
    display: flex;
    align-items: center;
    font-weight: $weight-bold;

    @include respond-to('md') {
      display: grid;
      grid-template-columns: auto 1fr;
      grid-template-rows: auto 1fr;
    }

    &__num {
      padding-right: $spacing-md;
      font-size: $font-size-base;
      color: $color-text-secondary;

      @include respond-to('md') {
        width: 100%;
        display: block;
        grid-column: 1/3;
      }
    }

    &__label {
      margin-bottom: 0;
      margin-right: 28px;
      margin-top: 0;
      font-size: 4.8rem;

      @include respond-to('md') {
        margin-right: 18px;
        font-size: $font-size-3xl;
        grid-column: 1/2;
      }
    }

    &::after {
      content: '';
      margin-top: 3px;
      display: inline-block;
      width: 100%;
      border-top: 1px solid $color-text-secondary;

      @include respond-to('md') {
        grid-column: 2/3;
      }
    }
  }
</style>
