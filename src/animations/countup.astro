---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'countup',
  title: 'CountUp Animation',
  description: '数値をカウントアップするアニメーション',
  order: 6,
  tags: {
    primary: ['GSAP', 'ANIMATION'],
    free: ['number'],
  },
  keywords: ['countup', 'カウントアップ', 'number', 'innerText', 'gsap'],
  engine: ['gsap'],
  difficulty: 'basic',
});

const { preview = false } = Astro.props;

const codeExample = `import { gsap } from 'gsap';

const countFrom = 0;
const countTo = 100;
const countElement = document.querySelector('.countup-animation');

gsap.fromTo(countElement, { innerText: countFrom }, {
  innerText: countTo,
  duration: 2,
  ease: 'power3.out',
  onUpdate: function () {
    const progress = this.progress();
    const currentCount = Math.floor(countFrom + (countTo - countFrom) * progress);
    if (countElement) countElement.textContent = currentCount.toString();
  },
});`;

const htmlExample = `<div class="countup-animation" data-count="100">0</div>`;

const cssExample = `.countup-animation {
  font-size: 2.4rem;
  font-weight: bold;
}`;
---

{
  preview ? (
    <div class="countup-preview">
      <div class="countup-animation" data-count="100">0</div>
    </div>
  ) : (
    <>
      <p>{meta.description}</p>
      <div class="animation__box">
        <div class="countup-animation" data-count="100">0</div>
      </div>

      <section>
        <h2>GSAP</h2>
        <Code lang="js" code={codeExample} class="code -block" />
      </section>

      <h2>HTML / CSS</h2>
      <Code lang="html" code={htmlExample} class="code -block" />
      <Code lang="css" code={cssExample} class="code -block" />
    </>
  )
}

<style lang="scss">
  @use '../assets/css/pages/animations/_countup.scss';

  .countup-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const countFrom = 0;
    const countTo = Number(
      document
        .querySelector('.countup-animation[data-count]')
        ?.getAttribute('data-count') || 0
    );
    const countElement = document.querySelector('.countup-animation');

    if (!countElement) return;

    gsap.fromTo(
      countElement,
      { innerText: countFrom },
      {
        innerText: countTo,
        duration: 2,
        delay: 0.2,
        ease: 'power3.out',
        onUpdate: function () {
          const progress = this.progress();
          const currentCount = Math.floor(
            countFrom + (countTo - countFrom) * progress
          );
          countElement.textContent = currentCount.toString();
        },
        repeat: -1,
        repeatDelay: 1.2,
      }
    );
  });
</script>

