---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'text',
  title: 'Text Animation',
  description: 'テキストを文字単位でアニメーションさせるアニメーション',
  order: 5,
  tags: {
    primary: ['GSAP', 'ANIMATION', 'TRANSFORM'],
    free: ['SplitText', 'chars'],
  },
  keywords: ['text', 'テキスト', 'SplitText', 'chars', 'stagger', 'gsap'],
  engine: ['gsap'],
  difficulty: 'intermediate',
});

const { preview = false } = Astro.props;

const codeExample = `import { gsap } from 'gsap';
import { SplitText } from 'gsap/SplitText';

gsap.registerPlugin(SplitText);

document.addEventListener('DOMContentLoaded', () => {
  const text = document.querySelector('.text-animation');
  const splitText = new SplitText(text, { type: 'chars', linesClass: 'text-animation__line' });

  gsap.fromTo(splitText.chars, {
    display: 'inline-block',
    opacity: 0,
    y: '8px',
  }, {
    opacity: 1,
    y: 0,
    ease: 'ease',
    stagger: 0.05,
  });
});`;

const htmlExample = `<p class="text-animation">Hello World!</p>`;

const cssExample = `.text-animation {
  font-size: 2rem;
  font-weight: bold;
  text-align: center;
}`;
---

{
  preview ? (
    <div class='text-preview'>
      <p class='text-animation'>Hello World!</p>
    </div>
  ) : (
    <>
      <p>{meta.description}</p>
      <div class='animation__box'>
        <p class='text-animation'>Hello World!</p>
      </div>

      <section>
        <h2>GSAP</h2>
        <Code lang='js' code={codeExample} class='code -block' />
      </section>

      <h2>HTML / CSS</h2>
      <Code lang='html' code={htmlExample} class='code -block' />
      <Code lang='css' code={cssExample} class='code -block' />
    </>
  )
}

<style lang='scss'>
  @use '../assets/css/pages/animations/index';
  @use '../assets/css/pages/animations/_text.scss';

  .text-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(SplitText);

  document.addEventListener('DOMContentLoaded', () => {
    const text = document.querySelector('.text-animation');
    if (!text) return;

    const splitText = new SplitText(text, {
      type: 'chars',
      linesClass: 'text-animation__line',
    });

    gsap.fromTo(
      splitText.chars,
      {
        display: 'inline-block',
        opacity: 0,
        y: '8px',
      },
      {
        opacity: 1,
        y: 0,
        ease: 'ease',
        stagger: 0.05,
      }
    );
  });
</script>
