---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'lineWeight',
  title: 'LineWeight Animation',
  description: '線の太さをアニメーションさせる',
  order: 7,
  tags: {
    primary: ['CSS', 'KEYFRAME', 'ANIMATION'],
    free: ['stroke', 'svg'],
  },
  keywords: ['line', 'stroke', 'weight', 'svg', 'keyframes'],
  engine: ['css', 'svg'],
  difficulty: 'basic',
});

const { preview = false } = Astro.props;

const codeExample = `/* CSS（例） */
.lineWeight-animation__path {
  animation: lineWeight 2s ease-in-out infinite;
}

@keyframes lineWeight {
  0%, 100% { stroke-width: 1; }
  50% { stroke-width: 6; }
}`;

const htmlExample = `<svg class="lineWeight-animation" viewBox="0 0 100 100">
  <path class="lineWeight-animation__path" d="M10 50 L90 50" />
</svg>`;

const cssExample = `.lineWeight-animation__path {
  fill: none;
  stroke: #fff;
  stroke-linecap: round;
  animation: lineWeight 2s ease-in-out infinite;
}
@keyframes lineWeight {
  0%, 100% { stroke-width: 1; }
  50% { stroke-width: 6; }
}`;
---

{
  preview ? (
    <div class="lineWeight-preview">
      <svg class="lineWeight-animation" viewBox="0 0 100 100">
        <path class="lineWeight-animation__path" d="M10 50 L90 50" />
      </svg>
    </div>
  ) : (
    <>
      <p>{meta.description}</p>
      <div class="animation__box">
        <svg class="lineWeight-animation" viewBox="0 0 100 100">
          <path class="lineWeight-animation__path" d="M10 50 L90 50" />
        </svg>
      </div>

      <section>
        <h2>CSS</h2>
        <Code lang="css" code={codeExample} class="code -block" />
      </section>

      <h2>HTML / CSS</h2>
      <Code lang="html" code={htmlExample} class="code -block" />
      <Code lang="css" code={cssExample} class="code -block" />
    </>
  )
}

<style lang="scss">
  @use '../assets/css/pages/animations/_lineWeight.scss';

  .lineWeight-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }
</style>

