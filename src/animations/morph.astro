---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'morph',
  title: 'Morph Animation',
  description: 'SVGパスの形状を別の形状に変形させるアニメーション',
  order: 3,
  tags: {
    primary: ['GSAP', 'TRANSFORM', 'ANIMATION'],
    free: ['morph', 'svg'],
  },
  keywords: ['morph', '変形', 'svg path', 'gsap', 'MorphSVGPlugin'],
  engine: ['gsap', 'svg'],
  difficulty: 'advanced',
});

const { preview = false } = Astro.props;

const codeExample = `import { gsap } from 'gsap';
import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';
gsap.registerPlugin(MorphSVGPlugin);

// 円と四角のSVGパス
const circle = "M10 40C10 23.4315 23.4315 10 40 10C56.5685 10 70 23.4315 70 40C70 56.5685 56.5685 70 40 70C23.4315 70 10 56.5685 10 40Z";
const square = "M10,10 L70,10 L70,70 L10,70 Z";

// アニメーションの設定
const morph = gsap.timeline({
  repeat: -1,
  defaults: {
    duration: 1.5,
    ease: "power2.inOut"
  }
});

// アニメーションの軸を中心に設定
gsap.set("#morph-path", {
  transformOrigin: "center center"
});

// 1. 四角から円への変形
morph.to("#morph-path", {
  rotate: 180,
  morphSVG: {
    shape: circle,
    type: "rotational"
  }
})
// 2. 円から四角への変形
.to("#morph-path", {
  rotate: 0,
  morphSVG: {
    shape: square,
    type: "rotational",
    origin: "center center"
  }
});`;

const htmlExample = `<div class="morph-animation">
  <svg class="morph-animation__svg" xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 80 80">
    <path id="morph-path" d="M10,10 L70,10 L70,70 L10,70 Z" fill="#bcbcbc"></path>
  </svg>
</div>`;

const cssExample = `.morph-animation__svg {
  overflow: visible;
}`;
---

{
  preview ? (
    <div class='morph-preview'>
      <div class='morph-animation'>
        <svg
          class='morph-animation__svg'
          xmlns='http://www.w3.org/2000/svg'
          width='80'
          height='80'
          viewBox='0 0 80 80'
        >
          <path
            id='morph-path'
            d='M10,10 L70,10 L70,70 L10,70 Z'
            fill='#bcbcbc'
          />
        </svg>
      </div>
    </div>
  ) : (
    <>
      <p>{meta.description}</p>
      <div class='animation__box'>
        <div class='morph-animation'>
          <svg
            class='morph-animation__svg'
            xmlns='http://www.w3.org/2000/svg'
            width='140'
            height='140'
            viewBox='0 0 80 80'
          >
            <path
              id='morph-path'
              d='M10,10 L70,10 L70,70 L10,70 Z'
              fill='#bcbcbc'
            />
          </svg>
        </div>
      </div>

      <section>
        <h2>GSAP</h2>
        <Code lang='js' code={codeExample} class='code -block' />
      </section>

      <h2>HTML / CSS</h2>
      <Code lang='html' code={htmlExample} class='code -block' />
      <Code lang='css' code={cssExample} class='code -block' />
    </>
  )
}

<style lang='scss'>
  @use '../assets/css/pages/animations/index';
  @use '../assets/css/pages/animations/_morph.scss';

  .morph-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';
  gsap.registerPlugin(MorphSVGPlugin);

  document.addEventListener('DOMContentLoaded', () => {
    const circle =
      'M10 40C10 23.4315 23.4315 10 40 10C56.5685 10 70 23.4315 70 40C70 56.5685 56.5685 70 40 70C23.4315 70 10 56.5685 10 40Z';
    const square = 'M10,10 L70,10 L70,70 L10,70 Z';

    const morph = gsap.timeline({
      repeat: -1,
      defaults: {
        duration: 1.5,
        ease: 'power2.inOut',
      },
    });

    gsap.set('#morph-path', {
      transformOrigin: 'center center',
    });

    morph
      .to('#morph-path', {
        rotate: 180,
        morphSVG: {
          shape: circle,
          type: 'rotational',
        },
      })
      .to('#morph-path', {
        rotate: 0,
        morphSVG: {
          shape: square,
          type: 'rotational',
          origin: 'center center',
        },
      });
  });
</script>
