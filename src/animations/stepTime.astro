---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'stepTime',
  title: 'Step Time Animation',
  description: '秒針のようなアニメーションを作成する',
  order: 9,
  tags: {
    primary: ['GSAP', 'ANIMATION', 'TRANSFORM'],
    free: ['steps', 'clock'],
  },
  keywords: ['step', 'steps', 'clock', '秒針', 'gsap'],
  engine: ['gsap'],
  difficulty: 'basic',
});

const { preview = false } = Astro.props;

const codeExample = `import gsap from "gsap";

gsap.to(".stepTime__clockLine", {
  rotation: 360,
  duration: 60,
  repeat: -1,
  ease: 'steps(60)',
  transformOrigin: 'left center',
});
`;

const cssExample = `.stepTime {
  &__clock {
    position: relative;
    width: 200px;
    height: 200px;

    &Line {
      position: absolute;
      top: 50%;
      left: 50%;
      width: calc(50% - 24px);
      height: 2px;
      border-top: 2px solid #bcbcbc;
      transform-origin: left center;
      rotate: -90deg;
    }
  }
}
`;

const htmlExample = `<div class="stepTime__clock">
  <svg viewBox="0 0 200 200" width="200" height="200" class="stepTime__clock-svg">
    <circle cx="100" cy="100" r="90" fill="none" stroke="#bcbcbc" stroke-width="3"/>
  </svg>
  <div class="stepTime__clockLine"></div>
</div>`;
---

{
  preview ? (
    <div class="stepTime-preview">
      <div class="stepTime__clock">
        <div class="stepTime__clockCircle" />
        <div class="stepTime__clockLine" />
      </div>
    </div>
  ) : (
    <>
      <p class="animation__description">{meta.description}</p>
      <div class="animation__box">
        <div class="stepTime__clock">
          <div class="stepTime__clockCircle" />
          <div class="stepTime__clockLine" />
        </div>
      </div>

      <section class="animation__javaScript">
        <h2>GSAP</h2>
        <Code lang="js" code={codeExample} class="code -block" />
      </section>

      <section class="animation__markup">
        <h2>HTML / CSS</h2>
        <Code lang="html" code={htmlExample} class="code -block" />
        <Code lang="css" code={cssExample} class="code -block" />
      </section>
    </>
  )
}

<style lang="scss">
  @use '../assets/css/pages/animations/index';

  .stepTime {
    &__clock {
      position: relative;
      width: 140px;
      height: 140px;
      &Circle {
        width: 140px;
        height: 140px;
        border: 2px solid #bcbcbc;
        border-radius: 100%;
      }
      &Line {
        position: absolute;
        top: 50%;
        left: 50%;
        width: calc(50% - 24px);
        height: 2px;
        border-top: 2px solid #bcbcbc;
        transform-origin: left center;
        rotate: -90deg;
      }
    }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.to('.stepTime__clockLine', {
    rotation: 360,
    duration: 60,
    repeat: -1,
    ease: 'steps(60)',
    transformOrigin: 'left center',
  });
</script>
