---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'stepTime',
  title: 'Step Time Animation',
  description: '秒針のようなアニメーションを作成する',
  order: 9,
  tags: {
    primary: ['GSAP', 'ANIMATION', 'TRANSFORM'],
    free: ['steps', 'clock'],
  },
  keywords: ['step', 'steps', 'clock', '秒針', 'gsap'],
  engine: ['gsap'],
  difficulty: 'basic',
});

const { preview = false } = Astro.props;

const codeExample = `import gsap from "gsap";

gsap.to(".stepTime__clockLine", {
  rotation: 360,
  duration: 30,
  repeat: -1,
  ease: "steps(30)",
  transformOrigin: "left center"
});
`;

const cssExample = `.stepTime {
  &__clock {
    position: relative;
    width: 200px;
    height: 200px;

    &Line {
      border-top: 2px solid #333;
      width: calc(50% - 24px);
      height: 2px;
      position: absolute;
      top: 50%;
      left: 50%;
      transform-origin: left center;
      rotate: -90deg;
    }
  }
}
`;

const htmlExample = `<div class="stepTime__clock">
  <svg viewBox="0 0 200 200" width="200" height="200" class="stepTime__clock-svg">
    <circle cx="100" cy="100" r="90" fill="none" stroke="#333" stroke-width="3"/>
  </svg>
  <div class="stepTime__clockLine"></div>
</div>`;
---

{
  preview ? (
    <div class="stepTime-preview">
      <div class="stepTime__clock">
        <svg
          viewBox="0 0 160 160"
          width="160"
          height="160"
          class="stepTime__clock-svg"
        >
          <circle
            cx="80"
            cy="80"
            r="70"
            fill="none"
            stroke="#333"
            stroke-width="3"
          ></circle>
        </svg>
        <div class="stepTime__clockLine"></div>
      </div>
    </div>
  ) : (
    <>
      <p>{meta.description}</p>

      <div class="animation__box">
        <div class="stepTime__clock">
          <svg
            viewBox="0 0 200 200"
            width="200"
            height="200"
            class="stepTime__clock-svg"
          >
            <circle
              cx="100"
              cy="100"
              r="90"
              fill="none"
              stroke="#333"
              stroke-width="3"
            ></circle>
          </svg>
          <div class="stepTime__clockLine"></div>
        </div>
      </div>

      <section>
        <h2>GSAP</h2>
        <Code lang="js" code={codeExample} class="code -block" />
      </section>

      <h2>HTML / CSS</h2>
      <Code lang="html" code={htmlExample} class="code -block" />
      <Code lang="css" code={cssExample} class="code -block" />
    </>
  )
}

<style lang="scss">
  .stepTime-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }

  .stepTime {
    &__clock {
      position: relative;
      width: 160px;
      height: 160px;

      &Line {
        border-top: 2px solid #333;
        width: calc(50% - 18px);
        height: 2px;
        position: absolute;
        top: 50%;
        left: 50%;
        transform-origin: left center;
        rotate: -90deg;
      }
    }
  }
</style>

<script>
  import gsap from 'gsap';

  gsap.to('.stepTime__clockLine', {
    rotation: 360,
    duration: 30,
    repeat: -1,
    ease: 'steps(30)',
    transformOrigin: 'left center',
  });
</script>

