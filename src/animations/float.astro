---
import { Code } from 'astro:components';
import { defineAnimationMeta } from '../assets/js/utils/animationMeta';

export const meta = defineAnimationMeta({
  slug: 'float',
  title: 'Float Animation',
  description: '滑らかに浮遊する要素の動き',
  order: 2,
  tags: {
    primary: ['GSAP', 'TRANSFORM', 'ANIMATION'],
    free: ['hover', 'y'],
  },
  keywords: ['float', '浮遊', 'y', 'gsap', 'fromTo'],
  engine: ['gsap'],
  difficulty: 'basic',
  snippet: {
    html: `<div class="float-animation"></div>`,
    css: `.float-animation {
  width: 100px;
  height: 100px;
  background: #bcbcbc;
  border-radius: 50%;
  margin: 2rem auto;
  transform-origin: center;
}`,
    js: `import { gsap } from 'gsap';

gsap.fromTo(
  '.float-animation',
  { y: 10 },
  { y: -10, repeat: -1, yoyo: true, duration: 1, ease: 'power2.inOut' }
);`,
  },
});

const { preview = false } = Astro.props;

const codeExample = `import { gsap } from 'gsap';
const float = gsap.fromTo(".float-animation", {
  y: 10,
}, {
  y: -10,
  repeat: -1,
  yoyo: true,
  duration: 1,
  ease: "power2.inOut",
});`;

const htmlExample = `<div class="float-animation"></div>`;

const cssExample = `.float-animation {
    width: 100px;
    height: 100px;
    background: #bcbcbc;
    border-radius: 50%;
    margin: 2rem auto;
    transform-origin: center;
  }
`;
---

{
  preview ? (
    <div class="float-preview">
      <div class="float-animation" />
    </div>
  ) : (
    <>
      <p class="animation__description">{meta.description}</p>
      <div class="animation__box">
        <div class="float-animation" />
      </div>

      <section class="animation__javaScript">
        <h2>GSAP</h2>
        <Code lang="js" code={codeExample} class="code -block" />
      </section>

      <section class="animation__markup">
        <h2>HTML / CSS</h2>
        <Code lang="html" code={htmlExample} class="code -block" />
        <Code lang="css" code={cssExample} class="code -block" />
      </section>
    </>
  )
}

<style lang="scss">
  @use '../assets/css/pages/animations/index';
  .float-preview {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    height: 120px;
  }

  .float-animation {
    width: 60px;
    height: 60px;
    background: #bcbcbc;
    border-radius: 50%;
    transform-origin: center;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const floatElements = document.querySelectorAll('.float-animation');
    floatElements.forEach((element) => {
      gsap.fromTo(
        element,
        { y: 10 },
        {
          y: -10,
          repeat: -1,
          yoyo: true,
          duration: 1,
          ease: 'power2.inOut',
        }
      );
    });
  });
</script>
